<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:background="@drawable/home_bg"
    android:layout_height="match_parent"
    tools:context=".HomeFragment">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
       <LinearLayout
           android:orientation="horizontal"
           android:layout_width="match_parent"
           android:layout_height="wrap_content">
           <LinearLayout
               android:orientation="vertical"
               android:layout_margin="20dp"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content">
               <TextView
                   android:layout_weight="1"
                   android:textColor="@color/black"
                   android:textStyle="bold"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:text="Hello,Sandeep"
                   android:textSize="30sp"
                   />
               <TextView
                   android:textSize="20sp"
                   android:layout_weight="1"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:text="welcome to Travels"
                   />
       </LinearLayout>
           <ImageView
               android:layout_weight="1"
               android:layout_margin="20dp"
               android:layout_width="0dp"
               android:layout_height="100dp"
               android:background="@drawable/profile_icon"
               />
        </LinearLayout>
        <SearchView
            android:id="@+id/searchView"
            android:background="@drawable/toolbar_style"
            android:layout_width="350dp"
            android:layout_gravity="center"
            android:layout_height="55dp"
            app:iconifiedByDefault="false"
            app:searchIcon="@drawable/search_icon"
            android:queryHint="Search countries..."/>
        <HorizontalScrollView
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_margin="5dp"
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="125dp">
                    <androidx.cardview.widget.CardView
                        app:cardCornerRadius="50dp"
                        android:layout_width="90dp"
                        android:layout_height="90dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:src="@drawable/edenburge"
                            />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_gravity="bottom"
                        android:gravity="center"
                        android:textSize="15sp"
                        android:textColor="@color/black"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Edenburge"
                        />
                </LinearLayout>
                <LinearLayout
                    android:layout_margin="5dp"
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="125dp">
                    <androidx.cardview.widget.CardView
                        app:cardCornerRadius="50dp"
                        android:layout_width="90dp"
                        android:layout_height="90dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:src="@drawable/finland"
                            />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_gravity="bottom"
                        android:gravity="center"
                        android:textSize="15sp"
                        android:textColor="@color/black"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Finland"
                        />
                </LinearLayout>
                <LinearLayout
                    android:layout_margin="5dp"
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="125dp">
                    <androidx.cardview.widget.CardView
                        app:cardCornerRadius="50dp"
                        android:layout_width="90dp"
                        android:layout_height="90dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:src="@drawable/switzerland"
                            />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_gravity="bottom"
                        android:gravity="center"
                        android:textSize="15sp"
                        android:textColor="@color/black"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Switzerland"
                        />
                </LinearLayout>
                <LinearLayout
                    android:layout_margin="5dp"
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="125dp">
                    <androidx.cardview.widget.CardView
                        app:cardCornerRadius="50dp"
                        android:layout_width="90dp"
                        android:layout_height="90dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:src="@drawable/edenburge"
                            />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_gravity="bottom"
                        android:gravity="center"
                        android:textSize="15sp"
                        android:textColor="@color/black"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Edenburge"
                        />
                </LinearLayout>
                <LinearLayout
                    android:layout_margin="5dp"
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="125dp">
                    <androidx.cardview.widget.CardView
                        app:cardCornerRadius="50dp"
                        android:layout_width="90dp"
                        android:layout_height="90dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:src="@drawable/edenburge"
                            />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_gravity="bottom"
                        android:gravity="center"
                        android:textSize="15sp"
                        android:textColor="@color/black"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Edenburge"
                        />
                </LinearLayout>
                <LinearLayout
                    android:layout_margin="5dp"
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="125dp">
                    <androidx.cardview.widget.CardView
                        app:cardCornerRadius="50dp"
                        android:layout_width="90dp"
                        android:layout_height="90dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:src="@drawable/edenburge"
                            />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:layout_gravity="bottom"
                        android:gravity="center"
                        android:textSize="15sp"
                        android:textColor="@color/black"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Edenburge"
                        />
                </LinearLayout>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>


</FrameLayout>